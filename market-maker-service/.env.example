# ================================================================
# Trading Bot — environment template
#
# Copy to .env and fill in. Comments describe each layer's knobs.
# ================================================================

# --- Chain & operator key ---
SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_KEY
# Optional fallback RPCs (comma-separated). Used for read failover when primary is unavailable.
SEPOLIA_RPC_FALLBACKS=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY,https://sepolia.gateway.tenderly.co/YOUR_KEY
PRIVATE_KEY=your_private_key_here
CHAIN_ID=11155111

# --- Deployed token addresses ---
BTC_BETA_ADDR=0xYOUR_BTC_BETA_TOKEN_ADDRESS
USDT_BETA_ADDR=0xYOUR_USDT_BETA_TOKEN_ADDRESS
ETH_BETA_ADDR=0xYOUR_ETH_BETA_TOKEN_ADDRESS

# --- Uniswap V2 / V3 contracts (Sepolia) ---
V2_FACTORY=0xYOUR_V2_FACTORY_ADDRESS
V2_ROUTER=0xYOUR_V2_ROUTER_ADDRESS
V3_FACTORY=0xYOUR_V3_FACTORY_ADDRESS
V3_QUOTER=0xYOUR_V3_QUOTER_ADDRESS
V3_SWAP_ROUTER=0xYOUR_V3_SWAP_ROUTER_ADDRESS

# --- Uniswap V4 contracts (Sepolia) ---
# Pool manager + swap router (PoolSwapTest, canonical periphery) + V4Quoter.
V4_POOL_MANAGER=0xYOUR_V4_POOL_MANAGER_ADDRESS
V4_SWAP_ROUTER=0xYOUR_V4_SWAP_ROUTER_ADDRESS
V4_QUOTER=0xYOUR_V4_QUOTER_ADDRESS

# --- Pool addresses (set these after running the pool deployment scripts) ---
V2_PAIR=0xYOUR_V2_PAIR_ADDRESS
V3_POOL=0xYOUR_V3_POOL_ADDRESS

# V4 pool keys: use either a single pool address (legacy form) OR the full
# PoolKey: "currency0,currency1,fee,tickSpacing,hooks". The full form is
# strongly preferred, since the bot reads price straight from PoolManager
# storage by hashing the PoolKey.
V4_POOL_BTC_USDT=
V4_POOL_ETH_USDT=
V4_POOL_ETH_BTC=

# --- Binance + bot api ---
BINANCE_WS_URL=wss://stream.binance.com:9443
API_PORT=8080
DB_PATH=data/trading.db
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUEUE=mm:audit:events
REDIS_LOCK_TTL_SEC=15

# --- Strategy knobs (per instrument unless overridden) ---
DEADBAND=0.0030             # |dev| < 0.30% -> hold
GAIN=0.30                   # notional ∝ gain * dev * MAX_NOTIONAL_USD
MIN_NOTIONAL_USD=50
MAX_NOTIONAL_USD=2000
COOLDOWN_SEC=30             # min seconds between two trades on the same pool

# --- Risk knobs ---
CIRCUIT_BREAKER=0.05        # 5% deviation -> circuit opens
CIRCUIT_COOLDOWN_SEC=120    # circuit auto-closes after 2 min
MIN_DEVIATION=0.005         # global lower bound (deadband still wins per inst)
MAX_SLIPPAGE=0.01
GAS_CAP_GWEI=50             # hard cap on gasFeeCap
MAX_GAS_USD=5.00            # USD budget per swap (uses live ETH price)
MIN_NET_EDGE_USD=1.00       # required edge after gas to fire a swap
DAILY_BUDGET_USD=250
TRIGGER_BPS=30
TWAP_WINDOW_SEC=45
TWAP_SLICE_COUNT=3

# --- Auth / RBAC ---
API_AUTH_SECRET=change_me
OPERATOR_WALLET=0xYourOperatorWallet

# --- Aggregator cadence ---
POLL_INTERVAL_MS=2000
